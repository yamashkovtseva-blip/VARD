---
import { useTranslations, type Lang } from '../i18n/translations';
interface Props { lang?: Lang }
const { lang = 'en' } = Astro.props;
const t = useTranslations(lang);
---
<section class="relative overflow-hidden border-y border-chalk/10">
  <div class="pointer-events-none absolute inset-0 opacity-40">
    <div class="absolute left-1/2 top-1/2 h-[800px] w-[800px] -translate-x-1/2 -translate-y-1/2 rounded-full bg-logo-gradient opacity-20 blur-3xl"></div>
  </div>

  <div class="container-narrow relative py-24 text-center lg:py-32">
    <h2 class="text-balance text-4xl font-semibold tracking-tight text-chalk sm:text-5xl">
      {t.finalCta.titleA}<br/>
      <span class="text-gradient">{t.finalCta.titleB}</span>
    </h2>

    <div class="mt-10 flex flex-col items-center justify-center gap-3 sm:flex-row">
      <a href="https://github.com/smarianna24/VARD" class="btn-primary">
        <svg width="14" height="14" viewBox="0 0 16 16" fill="currentColor"><path d="M3 1h10a1 1 0 0 1 1 1v12a1 1 0 0 1-1 1H3a1 1 0 0 1-1-1V2a1 1 0 0 1 1-1Zm2 3h6v2H5V4Zm0 4h6v2H5V8Zm0 4h4v2H5v-2Z"/></svg>
        {t.finalCta.ctaPrimary}
      </a>
      <a href="#contact" class="btn-secondary">{t.finalCta.ctaSecondary}</a>
    </div>
  </div>
</section>
