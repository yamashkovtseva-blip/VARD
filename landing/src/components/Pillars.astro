---
import { useTranslations, type Lang } from '../i18n/translations';
interface Props { lang?: Lang }
const { lang = 'en' } = Astro.props;
const t = useTranslations(lang);

const styling = [
  { iconWrap: 'border-teal/30 bg-teal/10 text-teal-light', line: 'via-teal/40', iconPath: 'M5 8V5a3 3 0 0 1 6 0v3M3 8h10v6H3z' },
  { iconWrap: 'border-violet/30 bg-violet/10 text-violet-light', line: 'via-violet/40', iconPath: 'M8 1v3M8 12v3M3.05 3.05l2.12 2.12M10.83 10.83l2.12 2.12M1 8h3M12 8h3M3.05 12.95l2.12-2.12M10.83 5.17l2.12-2.12' },
  { iconWrap: 'border-navy/30 bg-navy/10 text-navy-light', line: 'via-navy/40', iconPath: 'M5 7a2 2 0 1 0 0-4 2 2 0 0 0 0 4ZM11 7a2 2 0 1 0 0-4 2 2 0 0 0 0 4ZM2 14a3 3 0 0 1 6 0M8 14a3 3 0 0 1 6 0' },
];

const pillars = t.pillars.items.map((p, i) => ({ ...p, ...styling[i] }));
---
<section id="product" class="container-wide py-24 lg:py-32">
  <div class="mx-auto max-w-2xl text-center">
    <p class="mb-3 text-xs uppercase tracking-wider text-teal-light">{t.pillars.eyebrow}</p>
    <h2 class="text-balance text-3xl font-semibold tracking-tight text-chalk sm:text-4xl">{t.pillars.title}</h2>
  </div>

  <div class="mt-16 grid gap-6 md:grid-cols-3">
    {pillars.map((p) => (
      <div class="card group relative overflow-hidden p-7 transition hover:border-chalk/20">
        <div class={`mb-5 inline-flex h-10 w-10 items-center justify-center rounded-lg border ${p.iconWrap}`}>
          <svg width="18" height="18" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
            <path d={p.iconPath}/>
          </svg>
        </div>
        <h3 class="mb-2 text-lg font-semibold text-chalk">{p.title}</h3>
        <p class="text-sm leading-relaxed text-chalk-dim">{p.body}</p>
        <div class={`absolute inset-x-0 bottom-0 h-px bg-gradient-to-r from-transparent ${p.line} to-transparent opacity-0 transition group-hover:opacity-100`}></div>
      </div>
    ))}
  </div>
</section>
