---
import Logo from './Logo.astro';
import LangToggle from './LangToggle.astro';
import { useTranslations, type Lang, langPath } from '../i18n/translations';
interface Props { lang?: Lang }
const { lang = 'en' } = Astro.props;
const t = useTranslations(lang);
const home = langPath(lang, '/');
---
<header class="sticky top-0 z-40 border-b border-chalk/10 bg-ink-950/70 backdrop-blur-md">
  <nav class="container-wide flex h-16 items-center justify-between">
    <a href={home} class="flex items-center gap-2">
      <Logo size={28} />
      <span class="text-base font-semibold tracking-tight text-chalk">Vard</span>
    </a>

    <ul class="hidden items-center gap-7 text-sm text-chalk-dim md:flex">
      <li><a href="#product" class="transition hover:text-chalk">{t.nav.product}</a></li>
      <li><a href="#how" class="transition hover:text-chalk">{t.nav.docs}</a></li>
      <li><a href="#pricing" class="transition hover:text-chalk">{t.nav.pricing}</a></li>
    </ul>

    <div class="flex items-center gap-3">
      <LangToggle lang={lang} />
      <a
        href="https://github.com/smarianna24/VARD"
        aria-label="GitHub"
        class="hidden items-center gap-2 rounded-md border border-chalk/15 bg-ink-800/40 px-3 py-1.5 text-xs text-chalk-dim transition hover:border-chalk/30 hover:text-chalk sm:inline-flex"
      >
        <svg width="14" height="14" viewBox="0 0 16 16" fill="currentColor"><path d="M8 0C3.58 0 0 3.58 0 8c0 3.54 2.29 6.53 5.47 7.59.4.07.55-.17.55-.38 0-.19-.01-.82-.01-1.49-2.01.37-2.53-.49-2.69-.94-.09-.23-.48-.94-.82-1.13-.28-.15-.68-.52-.01-.53.63-.01 1.08.58 1.23.82.72 1.21 1.87.87 2.33.66.07-.52.28-.87.51-1.07-1.78-.2-3.64-.89-3.64-3.95 0-.87.31-1.59.82-2.15-.08-.2-.36-1.02.08-2.12 0 0 .67-.21 2.2.82.64-.18 1.32-.27 2-.27s1.36.09 2 .27c1.53-1.04 2.2-.82 2.2-.82.44 1.1.16 1.92.08 2.12.51.56.82 1.27.82 2.15 0 3.07-1.87 3.75-3.65 3.95.29.25.54.73.54 1.48 0 1.07-.01 1.93-.01 2.2 0 .21.15.46.55.38A8.012 8.012 0 0 0 16 8c0-4.42-3.58-8-8-8Z"/></svg>
        <span>GitHub</span>
      </a>
      <a href="https://vard.ru.tuna.am/login" class="hidden text-sm text-chalk-dim hover:text-chalk sm:inline-block">{t.nav.signin}</a>
      <a href="#how" class="btn-primary !py-2 !text-sm">{t.nav.cta}</a>
    </div>
  </nav>
</header>
