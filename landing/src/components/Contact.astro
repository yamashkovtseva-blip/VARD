---
import { useTranslations, type Lang } from '../i18n/translations';
interface Props { lang?: Lang }
const { lang = 'en' } = Astro.props;
const t = useTranslations(lang);
const c = t.contact;
---
<section id="contact" class="container-wide py-24 lg:py-32">
  <div class="grid gap-10 lg:grid-cols-2 lg:items-start lg:gap-16">
    <div>
      <p class="mb-3 text-xs uppercase tracking-wider text-teal-light">{c.eyebrow}</p>
      <h2 class="text-balance text-3xl font-semibold tracking-tight text-chalk sm:text-4xl">{c.title}</h2>
      <p class="mt-4 text-pretty text-base leading-relaxed text-chalk-dim max-w-md">{c.body}</p>

      <div class="mt-10 space-y-4">
        <a href={`mailto:${c.email}`} class="card flex items-center justify-between p-5 transition hover:border-teal/30">
          <div>
            <div class="text-xs uppercase tracking-wider text-chalk-mute">{c.emailLabel}</div>
            <div class="mt-1 font-mono text-base text-chalk">{c.email}</div>
          </div>
          <span class="text-chalk-mute">→</span>
        </a>
        <a href={`https://${c.githubHref}`} class="card flex items-center justify-between p-5 transition hover:border-violet/30">
          <div>
            <div class="text-xs uppercase tracking-wider text-chalk-mute">{c.githubLabel}</div>
            <div class="mt-1 font-mono text-base text-chalk">{c.githubHref}</div>
          </div>
          <span class="text-chalk-mute">→</span>
        </a>
        <a href={`https://${c.demoHref}`} class="card flex items-center justify-between p-5 transition hover:border-teal/30">
          <div>
            <div class="text-xs uppercase tracking-wider text-chalk-mute">{c.demoLabel}</div>
            <div class="mt-1 font-mono text-base text-chalk">{c.demoHref}</div>
          </div>
          <span class="text-chalk-mute">→</span>
        </a>
      </div>
    </div>

    <form
      class="card p-7 space-y-5"
      action={`mailto:${c.email}`}
      method="post"
      enctype="text/plain"
    >
      <div>
        <label for="contact-name" class="mb-2 block text-xs uppercase tracking-wider text-chalk-mute">{c.formNameLabel}</label>
        <input
          id="contact-name"
          name="name"
          type="text"
          required
          placeholder={c.formNamePlaceholder}
          class="w-full rounded-md border border-chalk/15 bg-ink-800/40 px-4 py-2.5 text-sm text-chalk placeholder:text-chalk-mute focus:border-teal/50 focus:outline-none"
        />
      </div>
      <div>
        <label for="contact-email" class="mb-2 block text-xs uppercase tracking-wider text-chalk-mute">{c.formEmailLabel}</label>
        <input
          id="contact-email"
          name="email"
          type="email"
          required
          placeholder={c.formEmailPlaceholder}
          class="w-full rounded-md border border-chalk/15 bg-ink-800/40 px-4 py-2.5 text-sm text-chalk placeholder:text-chalk-mute focus:border-teal/50 focus:outline-none"
        />
      </div>
      <div>
        <label for="contact-msg" class="mb-2 block text-xs uppercase tracking-wider text-chalk-mute">{c.formMsgLabel}</label>
        <textarea
          id="contact-msg"
          name="message"
          rows="5"
          required
          placeholder={c.formMsgPlaceholder}
          class="w-full resize-none rounded-md border border-chalk/15 bg-ink-800/40 px-4 py-2.5 text-sm text-chalk placeholder:text-chalk-mute focus:border-teal/50 focus:outline-none"
        ></textarea>
      </div>
      <button type="submit" class="btn-primary w-full">{c.formCta}</button>
      <p class="text-xs text-chalk-mute">{c.formNote}</p>
    </form>
  </div>
</section>
