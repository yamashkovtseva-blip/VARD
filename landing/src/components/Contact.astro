---
import { useTranslations, type Lang } from '../i18n/translations';
interface Props { lang?: Lang }
const { lang = 'en' } = Astro.props;
const t = useTranslations(lang);
const c = t.contact;
---
<section id="contact" class="container-wide py-24 lg:py-32">
  <div class="mx-auto max-w-3xl text-center">
    <p class="mb-3 text-xs uppercase tracking-wider text-teal-light">{c.eyebrow}</p>
    <h2 class="text-balance text-3xl font-semibold tracking-tight text-chalk sm:text-4xl">{c.title}</h2>
    <p class="mx-auto mt-4 max-w-xl text-pretty text-base leading-relaxed text-chalk-dim">{c.body}</p>
  </div>

  <div class="mx-auto mt-12 grid max-w-4xl gap-4 sm:grid-cols-3">
    <a href={`mailto:${c.email}`} class="card flex flex-col gap-2 p-6 transition hover:border-teal/30">
      <div class="text-xs uppercase tracking-wider text-chalk-mute">{c.emailLabel}</div>
      <div class="font-mono text-base text-chalk break-all">{c.email}</div>
      <div class="mt-auto pt-2 text-xs text-chalk-dim">{c.emailHint}</div>
    </a>
    <a href={`https://${c.githubHref}`} class="card flex flex-col gap-2 p-6 transition hover:border-violet/30">
      <div class="text-xs uppercase tracking-wider text-chalk-mute">{c.githubLabel}</div>
      <div class="font-mono text-base text-chalk break-all">{c.githubHref}</div>
      <div class="mt-auto pt-2 text-xs text-chalk-dim">{c.githubHint}</div>
    </a>
    <a href={`https://${c.demoHref}`} class="card flex flex-col gap-2 p-6 transition hover:border-teal/30">
      <div class="text-xs uppercase tracking-wider text-chalk-mute">{c.demoLabel}</div>
      <div class="font-mono text-base text-chalk break-all">{c.demoHref}</div>
      <div class="mt-auto pt-2 text-xs text-chalk-dim">{c.demoHint}</div>
    </a>
  </div>

  <p class="mx-auto mt-8 max-w-2xl text-center text-xs text-chalk-mute">{c.note}</p>
</section>
