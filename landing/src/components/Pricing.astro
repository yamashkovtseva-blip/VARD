---
import { useTranslations, type Lang } from '../i18n/translations';
interface Props { lang?: Lang }
const { lang = 'en' } = Astro.props;
const t = useTranslations(lang);

const tierMeta = [
  { highlight: false, href: 'https://github.com/nborodulin471/vard' },
  { highlight: true,  href: '#contact' },
  { highlight: false, href: '#contact' },
];

const tiers = t.pricing.tiers.map((tier, i) => ({ ...tier, ...tierMeta[i] }));

const rubMap: Record<string, string> = {
  '$0': '0 ₽',
  '$49': '≈ 4 500 ₽',
};
const showRub = lang === 'ru';
const rubNote = '≈ по курсу 90 ₽/$. Для РФ-клиентов — оплата по договору в рублях.';
---
<section id="pricing" class="container-wide py-24 lg:py-32">
  <div class="mx-auto max-w-2xl text-center">
    <h2 class="text-balance text-3xl font-semibold tracking-tight text-chalk sm:text-4xl">{t.pricing.title}</h2>
    <p class="mt-3 text-base text-chalk-dim">{t.pricing.subtitle}</p>
  </div>

  <div class="mx-auto mt-8 max-w-3xl">
    <div class="card flex items-start gap-3 border-teal/30 bg-teal/[0.04] p-5 text-left">
      <span class="mt-0.5 text-teal-light" aria-hidden="true">
        <svg width="18" height="18" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M8 1l5 2.5v4c0 3-2 5.5-5 6.5-3-1-5-3.5-5-6.5v-4L8 1Z"/><path d="M6 8l1.5 1.5L11 6"/></svg>
      </span>
      <p class="text-sm leading-relaxed text-chalk">{t.pricing.callout}</p>
    </div>
  </div>

  <div class="mt-12 grid gap-5 lg:grid-cols-3">
    {tiers.map((tier) => (
      <div class={`card relative p-6 ${tier.highlight ? 'border-teal/40 bg-gradient-to-b from-teal/[0.06] to-transparent' : ''}`}>
        {tier.badge && (
          <span class={`absolute -top-2 right-5 inline-flex rounded-full px-2.5 py-0.5 text-[10px] font-medium ${tier.highlight ? 'bg-teal text-ink-950' : 'border border-chalk/15 bg-ink-800 text-chalk-dim'}`}>
            {tier.badge}
          </span>
        )}
        <h3 class="text-base font-semibold text-chalk">{tier.name}</h3>
        <div class="mt-3 flex items-baseline gap-1">
          <span class="text-3xl font-semibold text-chalk">{tier.price}</span>
        </div>
        {showRub && rubMap[tier.price] && (
          <p class="mt-1 text-sm text-chalk-dim">{rubMap[tier.price]}</p>
        )}
        <p class="mt-1 text-xs text-chalk-mute">{tier.period}</p>
        <p class="mt-3 text-sm text-chalk-dim">{tier.pitch}</p>

        <a href={tier.href} class={`mt-5 flex w-full items-center justify-center rounded-md px-4 py-2.5 text-sm font-medium transition ${tier.highlight ? 'bg-chalk text-ink-950 hover:bg-white' : 'border border-chalk/15 bg-ink-800/40 text-chalk hover:border-chalk/30'}`}>
          {tier.cta}
        </a>

        <ul class="mt-6 space-y-2 border-t border-chalk/10 pt-5 text-sm text-chalk-dim">
          {tier.features.map((f) => (
            <li class="flex items-start gap-2">
              <span class="mt-0.5 text-teal-light">✓</span>
              <span>{f}</span>
            </li>
          ))}
        </ul>
      </div>
    ))}
  </div>

  {showRub && (
    <p class="mx-auto mt-6 max-w-2xl text-center text-xs text-chalk-mute">{rubNote}</p>
  )}

  <div class="mx-auto mt-24 max-w-3xl">
    <h3 class="mb-8 text-center text-2xl font-semibold tracking-tight text-chalk">{t.pricing.faqTitle}</h3>
    <div class="space-y-2">
      {t.pricing.faqs.map((f) => (
        <details class="group card overflow-hidden transition hover:border-chalk/20">
          <summary class="flex cursor-pointer list-none items-center justify-between px-6 py-4 text-base font-medium text-chalk">
            <span>{f.q}</span>
            <span class="text-chalk-mute transition group-open:rotate-45">+</span>
          </summary>
          <div class="border-t border-chalk/10 px-6 py-4 text-sm text-chalk-dim">{f.a}</div>
        </details>
      ))}
    </div>
  </div>
</section>
