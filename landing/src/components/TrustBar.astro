---
import { useTranslations, type Lang } from '../i18n/translations';
interface Props { lang?: Lang }
const { lang = 'en' } = Astro.props;
const t = useTranslations(lang);
---
<section class="border-y border-chalk/10 bg-ink-900/30">
  <div class="container-wide flex flex-col items-center gap-4 py-10 text-center">
    <span class="pill !text-[10px]">
      <span class="text-teal-light">●</span>
      {t.trustBar.eyebrow}
    </span>
    <p class="mx-auto max-w-2xl text-pretty text-base text-chalk-dim">{t.trustBar.message}</p>
    <a
      href="https://github.com/nborodulin471/vard"
      class="inline-flex items-center gap-2 rounded-md border border-chalk/15 bg-ink-800/40 px-4 py-2 text-sm text-chalk-dim transition hover:border-chalk/30 hover:text-chalk"
    >
      <span class="text-teal-light">⭐</span>
      <span>{t.trustBar.github}</span>
    </a>
  </div>
</section>
