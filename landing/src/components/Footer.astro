---
import Logo from './Logo.astro';
import { useTranslations, type Lang, langPath } from '../i18n/translations';
interface Props { lang?: Lang }
const { lang = 'en' } = Astro.props;
const t = useTranslations(lang);
const home = langPath(lang, '/');
---
<footer class="border-t border-chalk/10 bg-ink-900/40">
  <div class="container-wide py-12">
    <div class="grid gap-10 lg:grid-cols-3 lg:items-start">
      <div>
        <a href={home} class="inline-flex items-center gap-2">
          <Logo size={28} />
          <span class="text-base font-semibold tracking-tight text-chalk">Vard</span>
        </a>
        <p class="mt-4 max-w-xs text-sm text-chalk-dim">{t.footer.tagline}</p>
        <div class="mt-5 flex items-center gap-3">
          <a href="https://github.com/smarianna24/VARD" class="text-chalk-mute transition hover:text-chalk" aria-label="GitHub">
            <svg width="18" height="18" viewBox="0 0 16 16" fill="currentColor"><path d="M8 0C3.58 0 0 3.58 0 8c0 3.54 2.29 6.53 5.47 7.59.4.07.55-.17.55-.38 0-.19-.01-.82-.01-1.49-2.01.37-2.53-.49-2.69-.94-.09-.23-.48-.94-.82-1.13-.28-.15-.68-.52-.01-.53.63-.01 1.08.58 1.23.82.72 1.21 1.87.87 2.33.66.07-.52.28-.87.51-1.07-1.78-.2-3.64-.89-3.64-3.95 0-.87.31-1.59.82-2.15-.08-.2-.36-1.02.08-2.12 0 0 .67-.21 2.2.82.64-.18 1.32-.27 2-.27s1.36.09 2 .27c1.53-1.04 2.2-.82 2.2-.82.44 1.1.16 1.92.08 2.12.51.56.82 1.27.82 2.15 0 3.07-1.87 3.75-3.65 3.95.29.25.54.73.54 1.48 0 1.07-.01 1.93-.01 2.2 0 .21.15.46.55.38A8.012 8.012 0 0 0 16 8c0-4.42-3.58-8-8-8Z"/></svg>
          </a>
        </div>
      </div>

      <div>
        <h4 class="mb-4 text-xs uppercase tracking-wider text-chalk-mute">{t.footer.linksTitle}</h4>
        <ul class="space-y-2.5 text-sm text-chalk-dim">
          <li><a href="#pricing" class="transition hover:text-chalk">{t.footer.links.pricing}</a></li>
          <li><a href="https://github.com/smarianna24/VARD" class="transition hover:text-chalk">{t.footer.links.github}</a></li>
          <li><a href="https://vard.ru.tuna.am/login" class="transition hover:text-chalk">{t.footer.links.demo}</a></li>
          <li><a href={`mailto:${t.footer.links.email}`} class="transition hover:text-chalk">{t.footer.links.email}</a></li>
        </ul>
      </div>

      <div>
        <h4 class="mb-4 text-xs uppercase tracking-wider text-chalk-mute">{t.footer.legalTitle}</h4>
        <ul class="space-y-2.5 text-sm text-chalk-dim">
          <li><a href="https://mariadb.com/bsl11/" class="transition hover:text-chalk">{t.footer.legal.license}</a></li>
        </ul>
      </div>
    </div>

    <div class="mt-12 flex flex-col items-start justify-between gap-3 border-t border-chalk/10 pt-8 text-xs text-chalk-mute sm:flex-row sm:items-center">
      <span>{t.footer.copyright}</span>
      <span>{t.footer.madeWith}</span>
    </div>
  </div>
</footer>
